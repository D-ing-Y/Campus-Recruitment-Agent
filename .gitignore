.env
.venv/
__pycache__/
.pytest_cache/
.mypy_cache/
.ruff_cache/
dist/
build/
*.egg-info/

# Runtime data and private artifacts
data/evidence/**
data/runs/**
data/cache/**
data/reports/**
data/checkpoints/**
reports/**

!data/evidence/.gitkeep
!data/runs/.gitkeep
!data/cache/.gitkeep
!data/reports/.gitkeep
!data/checkpoints/.gitkeep
!reports/.gitkeep

# Local upstream source references. Track only the review metadata, not vendored repositories.
third_party/reference_sources/*
!third_party/reference_sources/README.md
!third_party/reference_sources/manifest.yaml
